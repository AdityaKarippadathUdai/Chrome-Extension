{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "jsx": "react-jsx",

    "strict": true,

    "skipLibCheck": true,

    "allowJs": false,
    "noEmit": true,
    "isolatedModules": true,

    "resolveJsonModule": true,

    "useDefineForClassFields": true,

    "moduleDetection": "force",

    "types": ["chrome", "webextension-polyfill"]
  },

  "include": [
    "src"
  ]
}
{
  "manifest_version": 3,
  "name": "Link Library",
  "version": "1.0.0",
  "description": "Save and organize links in folders.",

  "action": {
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "options_page": "options.html",

  "permissions": [
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ]
}